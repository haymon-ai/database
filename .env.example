# Database MCP Server Configuration
# Copy this file to .env and fill in your values
#
# Supports: --database-type mysql (default), postgres, sqlite
# For SQLite: use --db-path ./data.db instead of DB_HOST/DB_PORT/DB_USER/DB_PASSWORD

# === Database Connection (required for mysql/postgres) ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password

# === Database (optional) ===
DB_NAME=
DB_CHARSET=

# === SSL/TLS (optional) ===
DB_SSL=false
DB_SSL_CA=
DB_SSL_CERT=
DB_SSL_KEY=
DB_SSL_VERIFY_CERT=true
DB_SSL_VERIFY_IDENTITY=false

# === MCP Server ===
MCP_READ_ONLY=true
MCP_MAX_POOL_SIZE=10

# === CORS / Network (HTTP transport only) ===
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1
# Comma-separated list of allowed Host header values
ALLOWED_HOSTS=localhost,127.0.0.1

# === Logging ===
LOG_LEVEL=info
LOG_FILE=logs/mcp_server.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
